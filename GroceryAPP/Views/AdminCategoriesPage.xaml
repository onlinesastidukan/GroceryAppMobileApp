<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:GroceryApp.Converters"
             x:Class="GroceryApp.Views.AdminCategoriesPage"
             Title="सस्ती दुकान - Manage Shops"
             BackgroundColor="{StaticResource AppBackground}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:CategoryToIconConverter x:Key="CategoryIconConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Grid root: fixed header row, CollectionView scrolls in remaining space -->
    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="16,16,16,4">
            <VerticalStackLayout Spacing="2">
                <Label Text="Shops" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                <Label Text="Manage dealer shops" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
            </VerticalStackLayout>
            <Button Text="+ Add"
                    Clicked="OnAddShopClicked"
                    BackgroundColor="{StaticResource BrandPrimary}"
                    TextColor="White"
                    FontSize="13"
                    FontAttributes="Bold"
                    Padding="14,8"
                    CornerRadius="10"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Button.Shadow>
                    <Shadow Brush="#00b366" Opacity="0.3" Radius="6" Offset="0,3"/>
                </Button.Shadow>
            </Button>
        </Grid>

        <!-- Loading -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#00b366"
                           Scale="1.5"
                           Margin="0,20"/>

        <!-- Error -->
        <Label Grid.Row="2"
               Text="{Binding ErrorMessage}"
               IsVisible="{Binding HasError}"
               TextColor="#e74c3c"
               FontSize="14"
               FontAttributes="Bold"
               Margin="16,4"
               Padding="12"/>

        <!-- Categories grid — CollectionView handles its own scrolling -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Categories}"
                        SelectionMode="None"
                        Margin="16,8,16,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <Label Text="No shops yet"
                       TextColor="#999999"
                       HorizontalTextAlignment="Center"
                       Margin="0,40"
                       FontSize="14"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0" CornerRadius="16" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}" Margin="0">
                        <Frame.Shadow>
                            <Shadow Brush="#000000" Opacity="0.05" Radius="8" Offset="0,2"/>
                        </Frame.Shadow>
                        <VerticalStackLayout Spacing="12" Padding="14">
                            <Frame Padding="0"
                                   WidthRequest="56"
                                   HeightRequest="56"
                                   CornerRadius="28"
                                   HasShadow="False"
                                   BackgroundColor="#e8f5e9"
                                   HorizontalOptions="Center">
                                <Grid HeightRequest="56" WidthRequest="56">
                                    <Image Source="{Binding PhotoUrl, Converter={StaticResource Base64ImageSourceConverter}}"
                                           Aspect="AspectFill"
                                           HeightRequest="56" WidthRequest="56"
                                           IsVisible="{Binding PhotoUrl, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
                                    <Label Text="{Binding Name, Converter={StaticResource CategoryIconConverter}}"
                                           FontSize="32"
                                           IsVisible="{Binding PhotoUrl, Converter={StaticResource IsNullOrEmptyConverter}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Grid>
                            </Frame>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Fill">
                                <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="#1a1a1a" HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Description}" FontSize="11" TextColor="#666666" HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Button Grid.Column="0"
                                        Text="Edit"
                                        Clicked="OnEditShopClicked"
                                        BackgroundColor="#3498db"
                                        TextColor="White"
                                        FontSize="11"
                                        Padding="8,6"
                                        CornerRadius="8"
                                        CommandParameter="{Binding .}"/>
                                <Button Grid.Column="1"
                                        Text="Delete"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCategoryCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#e74c3c"
                                        TextColor="White"
                                        FontSize="11"
                                        Padding="8,6"
                                        CornerRadius="8"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
