<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.AdminDashboardPage"
             Title="Sasti Dukan - Admin"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <!-- Main Content -->
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20" BackgroundColor="#f8f9fa">
                <!-- Header with Hamburger Menu -->
                <Grid ColumnDefinitions="Auto,*" Margin="0,10" ColumnSpacing="15">
                    <Button Grid.Column="0"
                            Text="☰"
                            FontSize="22"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="8"
                            BackgroundColor="#f0f0f0"
                            TextColor="#1a1a1a"
                            Padding="0"
                            Clicked="OnMenuClicked"
                            VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="सस्ती दुकान" FontSize="32" FontAttributes="Bold" TextColor="#1a1a1a" FontFamily="{x:Null}"/>
                        <Label Text="Admin Dashboard" FontSize="16" TextColor="#666666"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Error Message -->
                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       TextColor="White"
                       BackgroundColor="#dc3545"
                       FontSize="14"
                       Padding="12"
                       Margin="0,10"/>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#00b366"
                                   Scale="1.5"
                                   Margin="0,20"/>

                <!-- Statistics Cards -->
                <Label Text="Quick Statistics" FontSize="18" FontAttributes="Bold" TextColor="#1a1a1a" Margin="0,10,0,0"/>

                <!-- First Row - Total Orders & Pending Orders -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame Grid.Column="0" Padding="0" CornerRadius="16" HasShadow="False" BorderColor="Transparent" Margin="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOrdersCardTapped"/>
                        </Frame.GestureRecognizers>
                        <Frame.Background>
                            <LinearGradientBrush>
                                <GradientStop Color="#007AFF" Offset="0"/>
                                <GradientStop Color="#0055CC" Offset="1"/>
                            </LinearGradientBrush>
                        </Frame.Background>
                        <VerticalStackLayout Spacing="8" Padding="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding TotalOrders}" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                            <Label Text="Total Orders" FontSize="13" TextColor="#E8F4FF" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <Frame.Shadow>
                            <Shadow Brush="#007AFF" Opacity="0.3" Radius="12" Offset="0,4"/>
                        </Frame.Shadow>
                    </Frame>

                    <Frame Grid.Column="1" Padding="0" CornerRadius="16" HasShadow="False" BorderColor="Transparent" Margin="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOrdersCardTapped"/>
                        </Frame.GestureRecognizers>
                        <Frame.Background>
                            <LinearGradientBrush>
                                <GradientStop Color="#FF6B35" Offset="0"/>
                                <GradientStop Color="#E8441A" Offset="1"/>
                            </LinearGradientBrush>
                        </Frame.Background>
                        <VerticalStackLayout Spacing="8" Padding="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding PendingOrders}" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                            <Label Text="Pending Orders" FontSize="13" TextColor="#FFE8E0" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <Frame.Shadow>
                            <Shadow Brush="#FF6B35" Opacity="0.3" Radius="12" Offset="0,4"/>
                        </Frame.Shadow>
                    </Frame>
                </Grid>

                <!-- Second Row - Products & Categories -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame Grid.Column="0" Padding="0" CornerRadius="16" HasShadow="False" BorderColor="Transparent" Margin="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProductsCardTapped"/>
                        </Frame.GestureRecognizers>
                        <Frame.Background>
                            <LinearGradientBrush>
                                <GradientStop Color="#ffc107" Offset="0"/>
                                <GradientStop Color="#ff8800" Offset="1"/>
                            </LinearGradientBrush>
                        </Frame.Background>
                        <VerticalStackLayout Spacing="8" Padding="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding TotalProducts}" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                            <Label Text="Products" FontSize="13" TextColor="#FFFBEE" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <Frame.Shadow>
                            <Shadow Brush="#ff8800" Opacity="0.3" Radius="12" Offset="0,4"/>
                        </Frame.Shadow>
                    </Frame>

                    <Frame Grid.Column="1" Padding="0" CornerRadius="16" HasShadow="False" BorderColor="Transparent" Margin="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoriesCardTapped"/>
                        </Frame.GestureRecognizers>
                        <Frame.Background>
                            <LinearGradientBrush>
                                <GradientStop Color="#6f42c1" Offset="0"/>
                                <GradientStop Color="#5a32a3" Offset="1"/>
                            </LinearGradientBrush>
                        </Frame.Background>
                        <VerticalStackLayout Spacing="8" Padding="16" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding TotalCategories}" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                            <Label Text="Categories" FontSize="13" TextColor="#F3E5F5" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <Frame.Shadow>
                            <Shadow Brush="#6f42c1" Opacity="0.3" Radius="12" Offset="0,4"/>
                        </Frame.Shadow>
                    </Frame>
                </Grid>

                <BoxView HeightRequest="20" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Dimmed overlay shown while menu is open -->
        <BoxView x:Name="Overlay"
                 BackgroundColor="#80000000"
                 Opacity="0"
                 IsVisible="False"
                 InputTransparent="False"
                 ZIndex="1">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

         <!-- Admin Side Menu -->
         <Frame x:Name="SideMenu"
               Padding="0"
               BackgroundColor="White"
               CornerRadius="0"
               HasShadow="False"
               IsVisible="False"
               TranslationX="-300"
               WidthRequest="280"
               HorizontalOptions="Start"
               VerticalOptions="Fill"
               ZIndex="2">
            <VerticalStackLayout Spacing="0">
                <Grid Padding="20,26,20,18" BackgroundColor="#00b366" ColumnDefinitions="*,Auto">
                    <Label Text="Admin Menu" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="✕" Clicked="OnCloseMenuClicked" BackgroundColor="Transparent" TextColor="White" FontSize="18"/>
                </Grid>

                <VerticalStackLayout Spacing="4" Padding="12,10">
                    <Border Stroke="#e9e9e9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuOrdersClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="View Orders" FontSize="15" TextColor="#1a1a1a"/>
                    </Border>

                    <Border Stroke="#e9e9e9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuProductsClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Manage Products" FontSize="15" TextColor="#1a1a1a"/>
                    </Border>

                    <Border Stroke="#e9e9e9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuCategoriesClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Manage Categories" FontSize="15" TextColor="#1a1a1a"/>
                    </Border>

                    <Border Stroke="#ffe1e1" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuLogoutClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Logout" FontSize="15" TextColor="#d64545"/>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>
