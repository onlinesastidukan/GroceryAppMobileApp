<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.CustomerProductPage"
             x:Name="CustomerProductPageRoot"
             x:DataType="local:CustomerProductViewModel"
             Title="सस्ती दुकान - Products"
             BackgroundColor="#fafafa"
             xmlns:local="clr-namespace:GroceryApp.ViewModels"
             xmlns:models="clr-namespace:GroceryApp.Models">
    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,12,16,8">
                <!-- Enhanced Header -->
                <VerticalStackLayout Margin="0,0,0,16" Spacing="4">
                    <Label Text="{Binding CategoryName}" FontSize="22" FontAttributes="Bold" FontAutoScalingEnabled="False" TextColor="#1a1a1a">
                        <Label.Shadow>
                            <Shadow Brush="#000000" Opacity="0.1" Radius="2" Offset="0,2"/>
                        </Label.Shadow>
                    </Label>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="⚡" FontSize="13"/>
                        <Label Text="Fast Delivery" FontSize="12" TextColor="#00b366" FontAttributes="Bold"/>
                        <Label Text="•" FontSize="12" TextColor="#999999"/>
                        <Label Text="Fresh Products" FontSize="12" TextColor="#666666"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}" 
                   IsVisible="{Binding HasError}" 
                   TextColor="#e74c3c" 
                   FontSize="12" 
                   Margin="0,0,0,8"/>

            <!-- Search Bar -->
            <Frame Padding="0" CornerRadius="12" HasShadow="False" BorderColor="#e8e8e8" Margin="0,0,0,4">
                <Frame.Shadow>
                    <Shadow Brush="#000000" Opacity="0.04" Radius="6" Offset="0,2"/>
                </Frame.Shadow>
                <SearchBar Placeholder="Search products..."
                           Text="{Binding SearchText}"
                           PlaceholderColor="#aaaaaa"
                           TextColor="#1a1a1a"
                           BackgroundColor="Transparent"
                           FontSize="14"
                           CancelButtonColor="#00b366"/>
            </Frame>
        </VerticalStackLayout>

        <!-- Products Grid - Enhanced 2 Column -->
        <CollectionView Grid.Row="1"
                        Margin="16,0,16,90"
                        ItemsSource="{Binding Products}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                        SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <!-- Premium Product Card -->
                        <Frame Padding="0" CornerRadius="14" HasShadow="False" BorderColor="#f0f0f0" BackgroundColor="#ffffff">
                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame" Binding="{Binding IsOutOfStock}" Value="True">
                                    <Setter Property="Opacity" Value="0.55"/>
                                </DataTrigger>
                            </Frame.Triggers>
                            <Frame.Shadow>
                                <Shadow Brush="#000000" Opacity="0.06" Radius="10" Offset="0,3"/>
                            </Frame.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <!-- Product Image Container -->
                                <Frame Padding="10" CornerRadius="14,14,0,0" HasShadow="False" BackgroundColor="#f8f8f8" Margin="0">
                                    <Image Source="{Binding ImageUrl, Converter={StaticResource Base64ImageSourceConverter}}" 
                                           Aspect="AspectFit"
                                           HeightRequest="100"
                                           WidthRequest="100"
                                           HorizontalOptions="Center"/>
                                </Frame>
                                
                                <!-- Product Info Section -->
                                <VerticalStackLayout Spacing="3" Padding="10,8,10,10">
                                    <!-- Product Name -->
                                    <Label Text="{Binding Name}" 
                                           FontSize="13" 
                                           FontAttributes="Bold" 
                                           TextColor="#1a1a1a"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                    
                                    <!-- Price & Add Button Row -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4" Margin="0,6,0,0">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding Price, StringFormat='₹{0:F0}'}" 
                                                   FontSize="16" 
                                                   FontAttributes="Bold" 
                                                   TextColor="#00b366"/>
                                            <Label Text="{Binding StockStatus}"
                                                   FontSize="10"
                                                   TextColor="#777777"/>
                                            <Label Text="Stocks unavailable"
                                                   FontSize="10"
                                                   FontAttributes="Bold"
                                                   TextColor="#d64545"
                                                   IsVisible="False">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsOutOfStock}" Value="True">
                                                        <Setter Property="IsVisible" Value="True"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>
                                        
                                        <!-- Enhanced Add Button -->
                                        <Button Grid.Column="1"
                                                Text="Add" 
                                                Clicked="OnAddToCartClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#00b366"
                                                TextColor="White"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                Padding="12,6"
                                                CornerRadius="8"
                                                WidthRequest="70"
                                                HeightRequest="30">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsOutOfStock}" Value="True">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                            <Button.Shadow>
                                                <Shadow Brush="#00b366" Opacity="0.3" Radius="4" Offset="0,2"/>
                                            </Button.Shadow>
                                        </Button>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

                <!-- Loading overlay while products are being fetched -->
                <Grid Grid.Row="1"
                            IsVisible="{Binding IsLoading}"
                            BackgroundColor="#CCFFFFFF"
                            Margin="0">
                        <VerticalStackLayout Spacing="10"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Center">
                                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                                                     IsVisible="{Binding IsLoading}"
                                                                     Color="#00b366"
                                                                     Scale="1.2"/>
                                <Label Text="Loading products..."
                                             FontSize="13"
                                             TextColor="#666666"
                                             HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                </Grid>
        
        <!-- Enhanced Floating Cart Button with count badge -->
        <Grid Grid.RowSpan="2"
              HorizontalOptions="End"
              VerticalOptions="End"
              Margin="20">
            <Button Text="🛒"
                    FontSize="24"
                    WidthRequest="64"
                    HeightRequest="64"
                    CornerRadius="32"
                    BackgroundColor="#00b366"
                    TextColor="White"
                    Clicked="OnCartClicked">
                <Button.Shadow>
                    <Shadow Brush="#00b366" Opacity="0.4" Radius="12" Offset="0,6"/>
                </Button.Shadow>
            </Button>

            <Border IsVisible="{Binding Source={x:Reference CustomerProductPageRoot}, Path=HasCartItems}"
                    BackgroundColor="#e74c3c"
                    StrokeThickness="0"
                    Padding="5,1"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    TranslationX="4"
                    TranslationY="-4"
                    StrokeShape="RoundRectangle 10">
                <Label Text="{Binding Source={x:Reference CustomerProductPageRoot}, Path=CartItemCount}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
