<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.CustomerProductPage"
             x:Name="CustomerProductPageRoot"
             x:DataType="local:CustomerProductViewModel"
             Title="सस्ती दुकान - Products"
             BackgroundColor="{StaticResource AppBackground}"
             xmlns:local="clr-namespace:GroceryApp.ViewModels"
             xmlns:models="clr-namespace:GroceryApp.Models">
    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,12,16,8">
                <!-- Enhanced Header -->
                <VerticalStackLayout Margin="0,0,0,16" Spacing="4">
                    <Label Text="{Binding CategoryName}" FontSize="24" FontAttributes="Bold" FontAutoScalingEnabled="False" TextColor="{StaticResource TextPrimary}">
                        <Label.Shadow>
                            <Shadow Brush="#000000" Opacity="0.1" Radius="2" Offset="0,2"/>
                        </Label.Shadow>
                    </Label>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="⚡" FontSize="13"/>
                        <Label Text="Fast Delivery" FontSize="12" TextColor="{StaticResource BrandAccent}" FontAttributes="Bold"/>
                        <Label Text="•" FontSize="12" TextColor="#94A3B8"/>
                        <Label Text="Fresh Products" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}" 
                   IsVisible="{Binding HasError}" 
                   TextColor="{StaticResource Danger}" 
                   FontSize="12" 
                   Margin="0,0,0,8"/>

            <!-- Search Bar -->
            <Frame Padding="0" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}" Margin="0,0,0,4">
                <Frame.Shadow>
                    <Shadow Brush="#000000" Opacity="0.04" Radius="6" Offset="0,2"/>
                </Frame.Shadow>
                <SearchBar Placeholder="Search products..."
                           Text="{Binding SearchText}"
                           PlaceholderColor="#94A3B8"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="Transparent"
                           FontSize="14"
                           CancelButtonColor="{StaticResource BrandPrimary}"/>
            </Frame>
        </VerticalStackLayout>

        <!-- Products Grid - Enhanced 2 Column -->
        <CollectionView Grid.Row="1"
                        Margin="16,0,16,90"
                        ItemsSource="{Binding Products}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                        SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <!-- Premium Product Card -->
                        <Frame Padding="0" CornerRadius="16" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame" Binding="{Binding IsOutOfStock}" Value="True">
                                    <Setter Property="Opacity" Value="0.55"/>
                                </DataTrigger>
                            </Frame.Triggers>
                            <Frame.Shadow>
                                <Shadow Brush="#000000" Opacity="0.06" Radius="10" Offset="0,3"/>
                            </Frame.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <!-- Product Image Container -->
                                <Frame Padding="10" CornerRadius="14,14,0,0" HasShadow="False" BackgroundColor="#f8f8f8" Margin="0">
                                    <Image Source="{Binding ImageUrl, Converter={StaticResource Base64ImageSourceConverter}}" 
                                           Aspect="AspectFit"
                                           HeightRequest="100"
                                           WidthRequest="100"
                                           HorizontalOptions="Center"/>
                                </Frame>
                                
                                <!-- Product Info Section -->
                                <VerticalStackLayout Spacing="3" Padding="10,8,10,10">
                                    <!-- Product Name -->
                                    <Label Text="{Binding Name}" 
                                           FontSize="13" 
                                           FontAttributes="Bold" 
                                           TextColor="{StaticResource TextPrimary}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                    <!-- Product Description -->
                                    <Label Text="{Binding Description}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
                                    <!-- Read More Button -->
                                    <Button Text="Read more ›"
                                            Clicked="OnReadMoreClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource BrandPrimary}"
                                            FontSize="11"
                                            FontAttributes="Bold"
                                            Padding="0,0"
                                            Margin="-4,0,0,0"
                                            HorizontalOptions="Start"
                                            HeightRequest="22"
                                            IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
                                    
                                    <!-- Price & Quantity Row -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4" Margin="0,6,0,0">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding Price, StringFormat='₹{0:F0}'}" 
                                                   FontSize="16" 
                                                   FontAttributes="Bold" 
                                                   TextColor="{StaticResource BrandAccent}"/>
                                            <Label Text="{Binding StockStatus}"
                                                   FontSize="10"
                                                   TextColor="#777777"/>
                                            <Label Text="Stocks unavailable"
                                                   FontSize="10"
                                                   FontAttributes="Bold"
                                                   TextColor="#d64545"
                                                   IsVisible="False">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsOutOfStock}" Value="True">
                                                        <Setter Property="IsVisible" Value="True"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </VerticalStackLayout>

                                        <!-- Add Button (hidden when out of stock) -->
                                        <Button Grid.Column="1"
                                                Text="Add"
                                                Clicked="OnAddToCartClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource BrandAccent}"
                                                TextColor="White"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                Padding="12,6"
                                                CornerRadius="8"
                                                WidthRequest="70"
                                                HeightRequest="30"
                                                VerticalOptions="Center">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsOutOfStock}" Value="True">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                            <Button.Shadow>
                                                <Shadow Brush="#00b366" Opacity="0.3" Radius="4" Offset="0,2"/>
                                            </Button.Shadow>
                                        </Button>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

                <!-- Loading overlay while products are being fetched -->
                <Grid Grid.Row="1"
                            IsVisible="{Binding IsLoading}"
                            BackgroundColor="#DDF8FAFC"
                            Margin="0">
                        <Frame Style="{StaticResource ModernCard}"
                               Padding="16"
                               WidthRequest="250"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <VerticalStackLayout Spacing="10">
                                <BoxView Style="{StaticResource SkeletonBlock}" HeightRequest="14" WidthRequest="190" HorizontalOptions="Center"/>
                                <BoxView Style="{StaticResource SkeletonBlock}" HeightRequest="12" WidthRequest="150" HorizontalOptions="Center"/>
                                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                                   IsVisible="{Binding IsLoading}"
                                                   Color="{StaticResource BrandPrimary}"
                                                   Scale="1.2"/>
                                <Label Text="Loading products..."
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                </Grid>

                <!-- Empty state: shown after fetch completes with no products -->
                <Grid Grid.Row="1"
                      IsVisible="{Binding HasNoProducts}"
                      BackgroundColor="{StaticResource AppBackground}"
                      Margin="0">
                    <Frame Style="{StaticResource ModernCard}" Padding="24" HorizontalOptions="Center" VerticalOptions="Center" MaximumWidthRequest="320">
                        <VerticalStackLayout Spacing="12" Padding="4">
                            <Label Text="🛒"
                                   FontSize="46"
                                   HorizontalTextAlignment="Center"
                                   Opacity="0.35"/>
                            <Label Text="No products available"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="There are currently no products in this category. Please check back later."
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>
        
        <!-- Enhanced Floating Cart Button with count badge -->
        <Grid Grid.RowSpan="2"
              HorizontalOptions="End"
              VerticalOptions="End"
              Margin="20">
            <Button Text="🛒"
                    FontSize="24"
                    WidthRequest="64"
                    HeightRequest="64"
                    CornerRadius="32"
                    BackgroundColor="{StaticResource BrandPrimary}"
                    TextColor="White"
                    Clicked="OnCartClicked">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource BrandPrimary}" Opacity="0.4" Radius="12" Offset="0,6"/>
                </Button.Shadow>
            </Button>

            <Border IsVisible="{Binding Source={x:Reference CustomerProductPageRoot}, Path=HasCartItems}"
                    BackgroundColor="#e74c3c"
                    StrokeThickness="0"
                    Padding="5,1"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    TranslationX="4"
                    TranslationY="-4"
                    StrokeShape="RoundRectangle 10">
                <Label Text="{Binding Source={x:Reference CustomerProductPageRoot}, Path=CartItemCount}"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Description Popup Overlay -->
        <Grid x:Name="DescriptionPopupOverlay"
              Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#80000000"
              ZIndex="10">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPopupBackgroundTapped"/>
            </Grid.GestureRecognizers>
            <Frame Padding="0"
                   CornerRadius="20"
                   HasShadow="False"
                   HorizontalOptions="Fill"
                   VerticalOptions="Center"
                   Margin="24,60"
                   BackgroundColor="White">
                <Frame.GestureRecognizers>
                    <!-- Absorb tap so it does not close the popup -->
                    <TapGestureRecognizer/>
                </Frame.GestureRecognizers>
                <Frame.Shadow>
                    <Shadow Brush="#000000" Opacity="0.2" Radius="20" Offset="0,8"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="0">
                    <!-- Popup Header -->
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="16,14,8,14"
                          BackgroundColor="#00b366">
                        <Label x:Name="PopupProductNameLabel"
                               Grid.Column="0"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"/>
                        <Button Grid.Column="1"
                                Text="✕"
                                FontSize="15"
                                WidthRequest="36"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                Padding="0"
                                Clicked="OnCloseDescriptionPopup"/>
                    </Grid>
                    <!-- Price & Stock Row -->
                    <HorizontalStackLayout Padding="16,10,16,4" Spacing="10">
                        <Label x:Name="PopupPriceLabel"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandAccent}"/>
                        <Label x:Name="PopupStockLabel"
                               FontSize="12"
                               TextColor="#777777"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <!-- Full Description -->
                    <BoxView HeightRequest="1" Color="#f0f0f0" Margin="16,0"/>
                    <ScrollView MaximumHeightRequest="320" Padding="16,12,16,20">
                        <Label x:Name="PopupDescriptionLabel"
                               FontSize="14"
                               TextColor="#333333"
                               LineBreakMode="WordWrap"
                               LineHeight="1.4"/>
                    </ScrollView>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
