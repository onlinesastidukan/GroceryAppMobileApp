<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.AdminOrderDetailPage"
             Title="Sasti Dukan - Order Detail">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="{Binding Order.OrderId, StringFormat='Order #{0}'}" FontSize="20" FontAttributes="Bold"/>
        <Picker Title="Status" ItemsSource="{Binding AvailableStatuses}" SelectedItem="{Binding SelectedStatus}"/>
        <Button Text="Update Status" Command="{Binding UpdateOrderStatusCommand}" BackgroundColor="#007AFF" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>
