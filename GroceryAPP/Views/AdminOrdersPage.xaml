<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.AdminOrdersPage"
             Title="Sasti Dukan - Manage Orders">
    <VerticalStackLayout Padding="20">
        <Label Text="Orders" FontSize="20" FontAttributes="Bold"/>
        <CollectionView ItemsSource="{Binding Orders}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame HasShadow="True" Margin="0,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding OrderId, StringFormat='Order #{0}'}" FontAttributes="Bold"/>
                            <Label Text="{Binding Status}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
