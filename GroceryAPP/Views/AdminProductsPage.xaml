<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.AdminProductsPage"
             Title="सस्ती दुकान - Manage Products"
             BackgroundColor="{StaticResource AppBackground}">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Logout"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnLogoutClicked" />
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16" RowSpacing="12">
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <VerticalStackLayout Spacing="2">
                <Label Text="Products" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                <Label Text="Manage your inventory" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
            </VerticalStackLayout>
            <Button Text="+ Add" 
                    Clicked="OnAddProductClicked" 
                    BackgroundColor="{StaticResource BrandPrimary}" 
                    TextColor="White" 
                    FontSize="13" 
                    FontAttributes="Bold" 
                    Padding="14,8" 
                    CornerRadius="10" 
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Button.Shadow>
                    <Shadow Brush="#00b366" Opacity="0.3" Radius="6" Offset="0,3"/>
                </Button.Shadow>
            </Button>
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               IsVisible="{Binding HasError}"
               TextColor="White"
               BackgroundColor="#dc3545"
               FontSize="13"
               Padding="10">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnErrorBannerTapped"/>
            </Label.GestureRecognizers>
        </Label>

        <!-- Search Bar -->
        <Frame Grid.Row="2" Padding="0" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
            <Frame.Shadow>
                <Shadow Brush="#000000" Opacity="0.04" Radius="6" Offset="0,2"/>
            </Frame.Shadow>
            <SearchBar Placeholder="Search products by name or description..."
                       Text="{Binding SearchText}"
                       PlaceholderColor="#aaaaaa"
                       TextColor="#1a1a1a"
                       BackgroundColor="Transparent"
                       FontSize="14"
                       CancelButtonColor="#00b366"/>
        </Frame>

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Products}"
                        SelectionMode="None"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <Label Text="No products found"
                       TextColor="#999999"
                       HorizontalTextAlignment="Center"
                       Margin="0,20,0,0"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0" CornerRadius="14" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}" Margin="0">
                        <Frame.Shadow>
                            <Shadow Brush="#000000" Opacity="0.05" Radius="8" Offset="0,2"/>
                        </Frame.Shadow>
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="95,*" Padding="14" ColumnSpacing="14" RowSpacing="12">
                            <!-- Product Image -->
                            <Frame Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" 
                                   Padding="8" 
                                   CornerRadius="10" 
                                   HasShadow="False" 
                                   BackgroundColor="#f8f8f8"
                                   WidthRequest="95"
                                   HeightRequest="95">
                                <Image Source="{Binding ImageUrl, Converter={StaticResource Base64ImageSourceConverter}}" 
                                        BackgroundColor="#f8f8f8"
                                       Aspect="AspectFit"
                                        WidthRequest="76"
                                        HeightRequest="76"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            
                            <!-- Product Info -->
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#1a1a1a" MaxLines="2" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Description}" FontSize="12" TextColor="#666666" MaxLines="2" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Price, StringFormat='₹{0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="#00b366" Margin="0,4,0,0"/>
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Label Text="{Binding Stock, StringFormat='Stock: {0}'}" FontSize="12" TextColor="#495057"/>
                                    <Label Text="OUT OF STOCK"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           BackgroundColor="#d64545"
                                           Padding="6,2"
                                           IsVisible="False">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsOutOfStock}" Value="True">
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            
                            <!-- Action Buttons -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                <Button Text="✏️ Edit" 
                                        Clicked="OnEditProductClicked"
                                        BackgroundColor="#3498db" 
                                        TextColor="White"
                                        FontSize="12"
                                        Padding="14,8"
                                        CornerRadius="8"
                                        HorizontalOptions="FillAndExpand"
                                        CommandParameter="{Binding .}">
                                    <Button.Shadow>
                                        <Shadow Brush="#3498db" Opacity="0.2" Radius="4" Offset="0,2"/>
                                    </Button.Shadow>
                                </Button>
                                <Button Text="➕ Stock"
                                        Clicked="OnRestockProductClicked"
                                        BackgroundColor="#f39c12"
                                        TextColor="White"
                                        FontSize="12"
                                        Padding="14,8"
                                        CornerRadius="8"
                                        HorizontalOptions="FillAndExpand"
                                        CommandParameter="{Binding .}"
                                        IsVisible="False">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsOutOfStock}" Value="True">
                                            <Setter Property="IsVisible" Value="True"/>
                                        </DataTrigger>
                                    </Button.Triggers>
                                    <Button.Shadow>
                                        <Shadow Brush="#f39c12" Opacity="0.2" Radius="4" Offset="0,2"/>
                                    </Button.Shadow>
                                </Button>
                                <Button Text="🗑️ Delete" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteProductCommand}" 
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#e74c3c" 
                                        TextColor="White"
                                        FontSize="12"
                                        Padding="14,8"
                                        CornerRadius="8"
                                        HorizontalOptions="FillAndExpand">
                                    <Button.Shadow>
                                        <Shadow Brush="#e74c3c" Opacity="0.2" Radius="4" Offset="0,2"/>
                                    </Button.Shadow>
                                </Button>
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading overlay for product list -->
        <Grid Grid.Row="3"
              IsVisible="{Binding IsLoading}"
              InputTransparent="False"
              BackgroundColor="#F8F9FA">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="14">
                <ActivityIndicator IsRunning="True"
                                   Color="#00b366"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   HorizontalOptions="Center"/>
                <Label Text="Loading products..."
                       FontSize="14"
                       TextColor="#666666"
                       HorizontalTextAlignment="Center"
                       FontAutoScalingEnabled="False"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
