<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:GroceryApp.Converters"
             x:Class="GroceryApp.Views.CustomerCategoryPage"
             x:Name="CustomerCategoryPageRoot"
             Title="सस्ती दुकान"
             BackgroundColor="{StaticResource AppBackground}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:CategoryToIconConverter x:Key="CategoryIconConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid Padding="0" RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,12,16,0" Spacing="14">
            <!-- Header with Hamburger Menu -->
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                <Button Grid.Column="0"
                        Grid.Row="0"
                        Text="☰"
                        FontSize="22"
                        Clicked="OnMenuClicked"
                        BackgroundColor="Transparent"
                        TextColor="#1a1a1a"
                        WidthRequest="44"
                        HeightRequest="44"/>

                <Label Grid.Column="1"
                       Grid.Row="0"
                       Text="Explore Local Shops"
                       FontSize="22"
                       FontAttributes="Bold"
                       FontAutoScalingEnabled="False"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextPrimary}">
                    <Label.Shadow>
                        <Shadow Brush="#000000" Opacity="0.1" Radius="2" Offset="0,2"/>
                    </Label.Shadow>
                </Label>

                <Grid Grid.Column="2" Grid.Row="0">
                    <Button Text="🛒"
                        FontSize="20"
                        Clicked="OnCartClicked"
                        BackgroundColor="Transparent"
                        TextColor="#00b366"
                        WidthRequest="44"
                        HeightRequest="44"/>

                    <Border IsVisible="{Binding Source={x:Reference CustomerCategoryPageRoot}, Path=HasCartItems}"
                        BackgroundColor="#e74c3c"
                        StrokeThickness="0"
                        Padding="4,1"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        TranslationX="4"
                        TranslationY="-2"
                        StrokeShape="RoundRectangle 10">
                    <Label Text="{Binding Source={x:Reference CustomerCategoryPageRoot}, Path=CartItemCount}"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                    </Border>
                </Grid>

                <HorizontalStackLayout Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Spacing="6">
                    <Label Text="⚡" FontSize="14"/>
                    <Label Text="Fast Delivery" FontSize="13" TextColor="{StaticResource BrandAccent}" FontAttributes="Bold"/>
                    <Label Text="•" FontSize="13" TextColor="#94A3B8"/>
                    <Label Text="Curated Grocery Shops" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                </HorizontalStackLayout>
            </Grid>
            
            <Label Text="{Binding ErrorMessage}" 
                   IsVisible="{Binding HasError}" 
                   TextColor="{StaticResource Danger}" 
                   FontSize="12"/>
            
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="#00b366" Margin="0,20"/>
        </VerticalStackLayout>

        <!-- Categories Grid with Dynamic Icons -->
        <CollectionView Grid.Row="1"
                        x:Name="CategoriesCollectionView"
                        Margin="16,8,16,16"
                        ItemsSource="{Binding Categories}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- Enhanced Category Card -->
                    <Frame Padding="0"
                           CornerRadius="16"
                           HasShadow="False"
                           BackgroundColor="{StaticResource Surface}"
                           BorderColor="{StaticResource BorderSubtle}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoryTapped"/>
                        </Frame.GestureRecognizers>
                        <Frame.Shadow>
                            <Shadow Brush="#000000" Opacity="0.06" Radius="8" Offset="0,2"/>
                        </Frame.Shadow>
                        <VerticalStackLayout Spacing="10" Padding="14">
                            <!-- Dynamic Icon / Photo Circle -->
                            <Frame Padding="0"
                                   WidthRequest="56"
                                   HeightRequest="56"
                                   CornerRadius="28"
                                   HasShadow="False"
                                   BackgroundColor="#e8f5e9"
                                   HorizontalOptions="Center">
                                <Frame.Shadow>
                                    <Shadow Brush="#00b366" Opacity="0.15" Radius="6" Offset="0,2"/>
                                </Frame.Shadow>
                                <Grid HeightRequest="56" WidthRequest="56">
                                    <Image Source="{Binding PhotoUrl, Converter={StaticResource Base64ImageSourceConverter}}"
                                           Aspect="AspectFill"
                                           HeightRequest="56" WidthRequest="56"
                                           IsVisible="{Binding PhotoUrl, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
                                    <Label Text="{Binding Name, Converter={StaticResource CategoryIconConverter}}"
                                           FontSize="32"
                                           IsVisible="{Binding PhotoUrl, Converter={StaticResource IsNullOrEmptyConverter}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Grid>
                            </Frame>

                            <!-- Shop Info -->
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Description}"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <!-- Dimmed overlay shown while menu is open -->
        <BoxView Grid.RowSpan="2"
             x:Name="MenuOverlay"
                 IsVisible="False"
                 BackgroundColor="#80000000"
                 Opacity="0"
                 InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Customer Side Menu -->
         <Frame Grid.RowSpan="2"
             x:Name="SideMenu"
               IsVisible="False"
               TranslationX="-300"
               WidthRequest="280"
               HorizontalOptions="Start"
               VerticalOptions="Fill"
               CornerRadius="0"
               Padding="0"
               HasShadow="False"
               BackgroundColor="White">
            <VerticalStackLayout Spacing="0">
                <Grid Padding="20,26,20,18" BackgroundColor="#00b366" ColumnDefinitions="*,Auto">
                    <Label Text="Customer Menu" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="✕" Clicked="OnCloseMenuClicked" BackgroundColor="Transparent" TextColor="White" FontSize="18"/>
                </Grid>

                <VerticalStackLayout Spacing="4" Padding="12,10">
                    <Border Stroke="#e9e9e9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuCategoriesClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="View Shops" FontSize="15" TextColor="#1a1a1a"/>
                    </Border>

                    <Border Stroke="#e9e9e9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuCartClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cart" FontSize="15" TextColor="#1a1a1a"/>
                    </Border>

                    <Border Stroke="#e9e9e9" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuPastOrdersClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Past Orders" FontSize="15" TextColor="#1a1a1a"/>
                    </Border>

                    <Border Stroke="#ffe1e1" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="12,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMenuLogoutClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="Logout" FontSize="15" TextColor="#d64545"/>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- Loading overlay shown while navigating to a shop -->
        <Grid Grid.RowSpan="2"
              x:Name="CategoryLoadingOverlay"
              IsVisible="False"
              BackgroundColor="#DDF8FAFC"
              InputTransparent="False">
            <Frame Style="{StaticResource ModernCard}"
                   Padding="16"
                   WidthRequest="240"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <VerticalStackLayout Spacing="10">
                    <BoxView Style="{StaticResource SkeletonBlock}" HeightRequest="14" WidthRequest="180" HorizontalOptions="Center"/>
                    <BoxView Style="{StaticResource SkeletonBlock}" HeightRequest="12" WidthRequest="150" HorizontalOptions="Center"/>
                    <ActivityIndicator IsRunning="True"
                                       Color="{StaticResource BrandPrimary}"
                                       WidthRequest="42"
                                       HeightRequest="42"
                                       HorizontalOptions="Center"/>
                    <Label Text="Loading products..."
                           FontSize="13"
                           FontAutoScalingEnabled="False"
                           TextColor="{StaticResource TextSecondary}"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
