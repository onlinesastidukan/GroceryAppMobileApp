<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.LoginPage"
             Title="सस्ती दुकान"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="Center">
            
            <!-- App Logo & Title -->
            <VerticalStackLayout Spacing="10" Margin="0,36,0,18" HorizontalOptions="Center">
                <!-- Emoji Logo -->
                <Frame Padding="0" 
                       WidthRequest="90" 
                       HeightRequest="90" 
                       CornerRadius="45" 
                       HasShadow="False" 
                       BackgroundColor="#e8f5e9"
                       HorizontalOptions="Center">
                    <Frame.Shadow>
                        <Shadow Brush="#00b366" Opacity="0.2" Radius="12" Offset="0,4"/>
                    </Frame.Shadow>
                    <Label Text="🛒" 
                           FontSize="48" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                </Frame>
                
                <!-- App Name -->
                <Label Text="सस्ती दुकान" 
                       FontSize="34" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center" 
                       TextColor="{StaticResource TextPrimary}">
                    <Label.Shadow>
                        <Shadow Brush="#000000" Opacity="0.1" Radius="2" Offset="0,2"/>
                    </Label.Shadow>
                </Label>
                <Label Text="Fresh groceries, local shops, and instant ordering"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource TextSecondary}"/>
            </VerticalStackLayout>
            
            <!-- Entry Options Card -->
            <Frame Padding="0" CornerRadius="22" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}" Margin="0,8,0,0">
                <Frame.Shadow>
                    <Shadow Brush="#000000" Opacity="0.08" Radius="16" Offset="0,4"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="18" Padding="24,28">

                    <Label Text="Choose your shopping mode"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalTextAlignment="Center"/>

                    <Button x:Name="GoToShopCustomerButton"
                            Text="🛍️ Customer"
                            Style="{StaticResource PrimaryCtaButton}"
                            Clicked="OnGoToShopCustomerClicked">
                        <Button.Shadow>
                            <Shadow Brush="#00b366" Opacity="0.4" Radius="10" Offset="0,5"/>
                        </Button.Shadow>
                    </Button>

                    <Label Text="Browse shops and place orders without login"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}"/>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderSubtle}" Margin="2,4"/>

                    <Button x:Name="GoToDealerButton"
                            Text="🏪 Dealer"
                            Style="{StaticResource SecondaryCtaButton}"
                            Clicked="OnGoToDealerClicked"/>

                    <Label Text="Login or register your shop to manage products and orders"
                           FontSize="13"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}"/>

                    <Label x:Name="ErrorLabel"
                           Text=""
                           TextColor="#e74c3c"
                           FontSize="13"
                           IsVisible="False"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>
            

            
            <!-- Footer -->
            <VerticalStackLayout Spacing="4" Margin="0,20,0,20" HorizontalOptions="Center">
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="⚡" FontSize="14"/>
                    <Label Text="Fast Delivery" FontSize="12" TextColor="#666666"/>
                    <Label Text="•" FontSize="12" TextColor="#999999"/>
                    <Label Text="🌿 Fresh Products" FontSize="12" TextColor="#666666"/>
                </HorizontalStackLayout>
                <Label Text="Made with ❤️ for local businesses" 
                       FontSize="11" 
                       TextColor="#999999"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
            
        </VerticalStackLayout>
    </ScrollView>

    <!-- Full-page loading overlay (always visible regardless of scroll position) -->
    <Grid x:Name="LoadingOverlay" IsVisible="False" BackgroundColor="#99FFFFFF">
        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="14">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               Color="#00b366"
                               Scale="1.4"
                               HorizontalOptions="Center"/>
            <Label Text="Loading..."
                   FontSize="15"
                   TextColor="#1a1a1a"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>
    </Grid>

    </Grid>
</ContentPage>
