<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryApp.Views.RegisterPage"
             Title="Shopkeeper Registration"
             BackgroundColor="{StaticResource AppBackground}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="8" Margin="0,20,0,10" HorizontalOptions="Center">
                <Frame Padding="0"
                       WidthRequest="80"
                       HeightRequest="80"
                       CornerRadius="40"
                       HasShadow="False"
                       BackgroundColor="#e8f5e9"
                       HorizontalOptions="Center">
                    <Frame.Shadow>
                        <Shadow Brush="#00b366" Opacity="0.2" Radius="10" Offset="0,4"/>
                    </Frame.Shadow>
                    <Label Text="🧾"
                           FontSize="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                </Frame>

                  <Label Text="दुकान जोड़ें"
                      FontSize="30"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource TextPrimary}"/>
                  <Label Text="Register your shop. Mobile number will be your secure User ID"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource TextSecondary}"/>
            </VerticalStackLayout>

            <!-- Form Card -->
            <Frame Padding="0" CornerRadius="20" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
                <Frame.Shadow>
                    <Shadow Brush="#000000" Opacity="0.08" Radius="16" Offset="0,4"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="16" Padding="22,22">


                    <VerticalStackLayout Spacing="6">
                        <Label Text="Shop Name" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Frame Padding="0" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
                            <Entry x:Name="FullNameEntry"
                                   Placeholder="Enter your shop name"
                                   ReturnType="Next"
                                   BackgroundColor="{StaticResource Surface}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="#94A3B8"
                                   FontSize="15"
                                   Margin="16,12"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Frame Padding="0" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="Create a password"
                                   IsPassword="True"
                                   ReturnType="Next"
                                   BackgroundColor="{StaticResource Surface}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="#94A3B8"
                                   FontSize="15"
                                   Margin="16,12"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mobile Number" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Frame Padding="0" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
                            <Entry x:Name="MobileEntry"
                                   Placeholder="Enter mobile number"
                                   Keyboard="Telephone"
                                   ReturnType="Next"
                                   BackgroundColor="{StaticResource Surface}"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="#94A3B8"
                                   FontSize="15"
                                   Margin="16,12"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Address" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Frame Padding="0" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" BackgroundColor="{StaticResource Surface}">
                            <Editor x:Name="AddressEntry"
                                    Placeholder="Enter delivery address"
                                    AutoSize="TextChanges"
                                    BackgroundColor="{StaticResource Surface}"
                                    TextColor="{StaticResource TextPrimary}"
                                    PlaceholderColor="#94A3B8"
                                    FontSize="15"
                                    HeightRequest="90"
                                    Margin="16,10"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Shop Image" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Frame Padding="8" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource BorderSubtle}" HeightRequest="140" BackgroundColor="#fafafa">
                            <Grid>
                                <VerticalStackLayout x:Name="ShopImagePlaceholder"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="6">
                                    <Label Text="🏪" FontSize="38" HorizontalTextAlignment="Center"/>
                                    <Label Text="No image selected" FontSize="12" TextColor="#999999" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                                <Image x:Name="ShopImagePreview"
                                       Aspect="AspectFit"
                                       IsVisible="False"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                        <Button Text="📷 Pick Shop Image"
                                Clicked="OnPickShopImageClicked"
                                BackgroundColor="#f0f0f0"
                                TextColor="#333333"
                                FontSize="13"
                                Padding="12,8"
                                CornerRadius="10"/>
                        <Label x:Name="ShopImageStatusLabel"
                               Text=""
                               FontSize="11"
                               TextColor="#00b366"
                               IsVisible="False"/>
                    </VerticalStackLayout>

                    <Label x:Name="ErrorLabel"
                           Text=""
                           TextColor="#e74c3c"
                           FontSize="12"
                           IsVisible="False"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Buttons inside ScrollView -->
            <VerticalStackLayout Spacing="10" Margin="0,20,0,400">
                <Button x:Name="CreateAccountButton"
                        Text="✅ दुकान जोड़ें"
                        Style="{StaticResource PrimaryCtaButton}"
                        Clicked="OnCreateAccountClicked">
                    <Button.Shadow>
                        <Shadow Brush="#00b366" Opacity="0.4" Radius="10" Offset="0,5"/>
                    </Button.Shadow>
                </Button>

                <Button x:Name="BackToLoginButton"
                        Text="Back to Login"
                        Style="{StaticResource SecondaryCtaButton}"
                        Clicked="OnBackToLoginClicked"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

        <!-- Loading Overlay -->
        <Grid BackgroundColor="#66000000" 
              InputTransparent="False" 
              IsVisible="{Binding Source={x:Reference LoadingIndicator}, Path=IsVisible}">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#00b366"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
